# EditorConfig — https://editorconfig.org
# Enforces a single baseline across editors so format decisions stop being
# per-author. Mirrors the existing style of src/ and public/tub/data/.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{md,mdx}]
# Markdown: preserve trailing two-space line breaks (hard wraps).
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
